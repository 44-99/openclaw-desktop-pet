# Hajixia Desktop Pet - Environment Variables
# Copy this file to .env and fill in your values

# ============================================
# App Settings
# ============================================
DEBUG=false

# Auto-chat interval (seconds) - Python backend only
# Note: Click-to-chat uses OpenClaw Gateway, not this setting
AUTO_CHAT_INTERVAL=300

# ============================================
# Future Features (Not yet implemented)
# ============================================

# Web Search (Tavily/Brave)
# SEARCH_API_KEY=your_search_api_key
# SEARCH_PROVIDER=tavily

# TTS (Text-to-Speech)
# TTS_API_KEY=your_tts_api_key
# TTS_PROVIDER=edge-tts

# ============================================
# Note: LLM Configuration
# ============================================
# Click-to-chat now uses OpenClaw Gateway (http://127.0.0.1:18789)
# No separate LLM API key needed here!
# The Gateway handles all LLM requests with your configured model.
